# ============================================================
# LAPAK BANTUL - Environment Variables Example
# Salin file ini menjadi .env dan isi dengan nilai asli Anda
# JANGAN commit file .env ke repository
# ============================================================

# ─── API Service (reqres.in) ────────────────────────────────
API_BASE_URL=https://reqres.in/api
API_KEY=your_api_key_here

# Demo credentials untuk testing (reqres.in):
# Login  → eve.holt@reqres.in / cityslicka
# Register → eve.holt@reqres.in / pistol

# ─── Google OAuth ────────────────────────────────────────────
# Server Client ID untuk Google Sign-In (mobile)
GOOGLE_SERVER_CLIENT_ID=your_google_server_client_id.apps.googleusercontent.com

# ─── Firebase — Shared ───────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app

# ─── Firebase — Web ──────────────────────────────────────────
FIREBASE_WEB_API_KEY=your_web_api_key
FIREBASE_WEB_APP_ID=1:your_sender_id:web:your_app_id
FIREBASE_WEB_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_WEB_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Firebase — Android ──────────────────────────────────────
FIREBASE_ANDROID_API_KEY=your_android_api_key
FIREBASE_ANDROID_APP_ID=1:your_sender_id:android:your_app_id

# ─── Firebase — iOS & macOS ──────────────────────────────────
FIREBASE_IOS_API_KEY=your_ios_api_key
FIREBASE_IOS_APP_ID=1:your_sender_id:ios:your_app_id
FIREBASE_IOS_CLIENT_ID=your_sender_id-xxxx.apps.googleusercontent.com
FIREBASE_IOS_BUNDLE_ID=com.example.lapakBantul

# ─── Firebase — Windows ──────────────────────────────────────
FIREBASE_WINDOWS_API_KEY=your_windows_api_key
FIREBASE_WINDOWS_APP_ID=1:your_sender_id:web:your_app_id
FIREBASE_WINDOWS_MEASUREMENT_ID=G-XXXXXXXXXX
